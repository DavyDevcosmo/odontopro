# You need to create 4 `.env.$(NODE_ENV)` files:
# .env.development, .env.production, .env.e2e, and .env.test
# .env.test is used for unit and integration tests (primarily) in Vitest
# .env.e2e is used for end-to-end tests in Playwright
# .env.development is used in your own development environment
# .env.production is used during the build and start of Next.js
# Check the src/env/configs.ts file for more details on how we handle environments

# Accepted values: development, test, e2e, production
CURRENT_ENV="THIS IS AN EXAMPLE - READ THE TEXT ABOV"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/psicopro"

# Safety flag for destructive test DB cleanup (only in .env.test)
# IS_TEST_DATABASE="true"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"  # alternative to AUTH_URL

# OAuth - Google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OAuth - GitHub (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PLAN_BASIC=""
STRIPE_PLAN_PROFESSIONAL=""
STRIPE_SUCCESS_URL="http://localhost:3000/dashboard/plans"
STRIPE_CANCEL_URL="http://localhost:3000/dashboard/plans"

# Cloudinary (profile image upload)
CLOUDINARY_NAME=""
CLOUDINARY_KEY=""
CLOUDINARY_SECRET=""

# Public URL (client-side fetches)
NEXT_PUBLIC_URL="http://localhost:3000"
